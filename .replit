modules = ["go-1.21", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./start"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["go", "run", "."]

[userenv]

[userenv.shared]
DEFAULT_POSITION_SIZE = "100"
MAX_POSITION_SIZE = "1000"
MAX_DAILY_LOSS = "500"
DB_PATH = "./clodds.db"
MAX_DAILY_TRADES = "20"
MIN_CONFIDENCE = "0.6"
MAX_POSITIONS = "10"
MAX_DRAWDOWN = "20"
TRADING_MODE = "balanced"
USER_ID = "cli-user"
AI_DEFAULT_MODEL = "google"
MAX_LEVERAGE = "5"
